{
  "exclude": [
    "LICENSE"
  ],
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 120,
    "proseWrap": "never",
    "semiColons": true,
    "singleQuote": false,
    "useTabs": false,
    "quoteProps": "consistent"
  },
  "tasks": {
    "build": {
      "description": "Formats, tests, builds and counts all modules.",
      "command": "deno fmt && deno test --allow-write --allow-read && deno -A build.ts --all && deno count.ts "
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@types/node": "npm:@types/node@^22.19.13"
  },
  "workspace": [
    "./number",
    "./string",
    "./geo",
    "./http",
    "./perf"
  ],
  "publish": {
    "exclude": [
      "LICENSE",
      "count.ts",
      "deno.lock",
      "**/CHANGELOG.md",
      "**/mod.test.ts"
    ]
  }
}
